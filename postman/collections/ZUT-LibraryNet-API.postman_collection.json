              "mode": "raw",
              "raw": "{\n  \"type\": \"student\",\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@zut.edu.zm\",\n  \"phone\": \"0977123456\",\n  \"studentId\": \"2024001\",\n  \"programme\": \"Computer Science\",\n  \"yearOfStudy\": 2\n}"
            },
            "url": {
